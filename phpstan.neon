includes:
	- phpstan-baseline.neon
	- vendor/szepeviktor/phpstan-wordpress/extension.neon

parameters:
	level: 5

	paths:
		- plugin.php
		- uninstall.php
		- src/

	excludePaths:
		- vendor/

	# SDK classes are provided by the development dependency in composer.json.
	scanDirectories:
		- %currentWorkingDirectory%/vendor/wordpress/php-ai-client/src/

	scanFiles:
		- %currentWorkingDirectory%/phpstan-stubs.php
